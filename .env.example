# CoreX Sales Service — local / deploy environment
# Copy to .env and fill secrets. .env is gitignored.
#
# Local dev:  cp .env.example .env && ./scripts/start-local.sh
#              (reads .env first; cloud-sql/env.local is optional fallback)

PORT=8080
HOST=127.0.0.1
COREX_SALES_SERVICE_ENV=local

# --- Cloud SQL (postgres-17-sandbox / corexbiz-db) ---
# Start proxy: /Users/tobymalek/corexbiz/cloud-sql/start-proxy.sh

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=corexbiz-db
POSTGRES_USER=postgres
# Quote passwords that contain $, >, spaces, etc.
POSTGRES_PASSWORD='your-password-here'
POSTGRES_SSLMODE=disable
POSTGRES_SCHEMA=sales-service
DB_AUTO_SEED=true

CLOUD_SQL_CONNECTION_NAME=corexbiz:us-west1:postgres-17-sandbox

# Optional full URL (otherwise built from POSTGRES_* with safe encoding)
# DATABASE_URL=postgresql://postgres:PASSWORD@127.0.0.1:5432/corexbiz-db?sslmode=disable

# Cloud Run deploy (unix socket)
# CLOUD_RUN_DATABASE_URL=postgresql://postgres:PASSWORD@/corexbiz-db?host=/cloudsql/corexbiz:us-west1:postgres-17-sandbox

# --- WordPress site (webhooks + run scoping) ---
# SALES_SITE_URL must match WP_SITEURL. SALES_SITE_ID must match WP SubscriptionService server_id.
SALES_SITE_URL=http://dev.corexbizhome.com:10004
SALES_SITE_ID=

# --- Pipeline / integrations ---
# Google Cloud API key — enable Places API + Geocoding API on the key (radius/center searches use Geocoding).
GOOGLE_MAPS_API_KEY=
WEBHOOK_SIGNING_SECRET=dev-sales-webhook-secret
API_TOKEN=dev-sales-service-token

# Admin UI (/admin) — optional locally; set on Cloud Run for request tracing
ADMIN_PASSWORD=dev-sales-admin-password
# ADMIN_SESSION_SECRET=  # defaults to API_TOKEN
# ADMIN_AUTH_DISABLED=1  # open admin without password (local only)
# ADMIN_SESSION_TTL_SEC=28800
# ADMIN_COOKIE_SECURE=1

# Logging (stdout structured lines)
LOG_LEVEL=INFO
# SALES_LOG_STRUCTURED=1
# SALES_LOG_RUN_POLLS=0
# SALES_LOG_PIPELINE_OUTPUT=0

SALES_WORKER_MODE=inline

# Cloud Run production: SALES_WORKER_MODE=job
# API dispatches full run spec via SALES_RUN_SPEC env on each job execution (no DB queue).

# --- Cloud Run (deploy.sh sets these on the service/job) ---
# GCP_PROJECT_ID=corexbiz
# GCP_REGION=us-west1
# SALES_CLOUD_RUN_JOB=corex-sales-pipeline-job-dev
# CLOUD_RUN_DEV_SERVICE=corex-sales-service-dev
# CLOUD_RUN_PRODUCTION_SERVICE=corexbiz-sales-service
# CLOUD_RUN_SERVICE_ACCOUNT=corex-sales-runner@corexbiz.iam.gserviceaccount.com
# SERVICE_MEMORY=1Gi
# SERVICE_CPU=1
# JOB_MEMORY=2Gi
# JOB_CPU=2
# CLOUD_RUN_REQUIRE_AUTH=0

# Optional Secret Manager refs (deploy.sh)
# SECRET_GOOGLE_MAPS_API_KEY=corex-sales-google-maps-api-key:latest
# SECRET_WEBHOOK_SIGNING_SECRET=corex-sales-webhook-signing-secret:latest
# SECRET_API_TOKEN=corex-sales-api-token:latest

# CORS_ALLOW_ORIGINS=*
